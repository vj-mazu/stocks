{
    "version": 2,
    "buildCommand": "cd client && npm install && npm run build",
    "outputDirectory": "client/build",
    "framework": null,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://mother-india-server.onrender.com/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
