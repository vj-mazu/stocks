{
    "buildCommand": "npm run build",
    "outputDirectory": "build",
    "installCommand": "npm install --legacy-peer-deps",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://mother-india-server.onrender.com/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
